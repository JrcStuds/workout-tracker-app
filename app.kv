#:kivy 2.3.1


<ExerciseSets>: # AnchorLayout that aligns to the top
    anchor_x: 'center'
    anchor_y: 'top'
    size_hint: (1.0, 1.0)
    
    BoxLayout: # for the headers, set inputs, and add set button
        id: set_container
        orientation: 'vertical'

        BoxLayout: # for the headers
            id: set_headers

            Label:
                text: 'Set'
            Label:
                text: 'Kg'
            Label:
                text: 'Reps'
            Label:
                text: 'RIR'
        
        # insert set input widgets here

        AnchorLayout: # to align the add set button
            anchor_x: 'center'
            anchor_y: 'center'

            Button: # add set button
                text: '+ Add Set'
                on_press: root.add_set()
                size_hint_x: 0.3


<SetInputRow>: # BoxLayout for the input fields
    orientation: 'horizontal'
    # size_hint_y: None
    # size_y: root.height * 0.1

    Label: # for the set number
        text: '1'

    TextInput:
    TextInput:
    TextInput: