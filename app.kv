#     size_hint_y: None

#     TextInput:
#     TextInput:
#     TextInput:
#     TextInput:


# <ExerciseSets>:
#     orientation: 'vertical'

#     Button:
#         text: '+ Add Row'
#         on_press: root.add_row()


<SetInputRow>:
    size_hint_y: None
    orientation: 'horizontal'
    padding: 5
    spacing: 5
    height: 50  # will be overridden by update_height
    canvas.before:
        Color:
            rgba: 0.6, 0.6, 0.6, 1
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

    TextInput:
        text: '0'
        multiline: False
        halign: 'center'
        valign: 'middle'
    TextInput:
        text: '0'
        multiline: False
        halign: 'center'
    TextInput:
        text: '0'
        multiline: False
        halign: 'center'
    TextInput:
        text: '0'
        multiline: False
        halign: 'center'

<ExerciseSets>:
    orientation: 'vertical'
    padding: 10
    spacing: 10

    BoxLayout:
        size_hint_y: None
        height: 30
        spacing: 5
        Label:
            text: 'Set'
        Label:
            text: 'Kg'
        Label:
            text: 'Reps'
        Label:
            text: 'RIR'

    ScrollView:
        do_scroll_x: False
        GridLayout:
            id: rows_container
            cols: 1
            size_hint_y: None
            height: self.minimum_height
            spacing: 5

    BoxLayout:
        size_hint_y: None
        height: 40
        Button:
            text: '+ Add Set'
            size_hint_x: None
            width: 120
            on_press: root.add_row()